# Firebase web config for CLOUD MODE. Set these in your host's environment
# (Netlify: Site settings → Environment variables) and the build step generates
# public/firebase-config.js for you — nothing project-specific gets committed.
#
# Values come from the Firebase console:
#   Project settings → General → Your apps → Web app → SDK setup → Config
# None of these are secret; a Firebase web config ships in the browser and your
# data is protected by Firestore security rules (firestore.rules) instead.
#
# Leave these unset to deploy in local/placeholder mode (no cloud persistence).

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-api-key
FIREBASE_APP_ID=your-app-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# Optional — default to <project-id>.firebaseapp.com / <project-id>.appspot.com
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
