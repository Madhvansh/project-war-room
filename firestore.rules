rules_version = '2';

// PROJECT WAR ROOM — Firestore security rules for cloud mode.
//
// The Firebase web config in the browser is public by design; THESE RULES are
// what actually protect the data. Every user can read and write ONLY their own
// record under users/{their-uid}/… and can see nothing belonging to anyone else.
//
// Deploy with:  firebase deploy --only firestore:rules
// (or paste into Firebase console → Firestore Database → Rules).

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else is denied by default.
  }
}
